# Token del bot (Panel de Discord Developer → Bot → Token)
TOKEN=your_bot_token_here

# Application ID (Panel de Discord Developer → General Information → Application ID)
CLIENT_ID=your_application_id_here

# ID del canal donde se lanzarán los eventos horarios automáticos
# (Activa Modo Desarrollador en Discord → clic derecho en el canal → Copiar ID)
EVENT_CHANNEL_ID=your_channel_id_here
